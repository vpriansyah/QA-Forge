# ═══════════════════════════════════════════════════════════
# QA Forge — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── APPLICATION ──────────────────────────────────────────
NODE_ENV=development
BACKEND_PORT=4000
FRONTEND_PORT=3000

# ─── GEMINI AI ──────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-4-26b-a4b-it

# ─── DATABASE (PostgreSQL) ───────────────────────────────
POSTGRES_DB=qaforge
POSTGRES_USER=qaforge
POSTGRES_PASSWORD=qaforge_pass
POSTGRES_PORT=5432
DATABASE_URL=postgresql://qaforge:qaforge_pass@localhost:5432/qaforge?schema=public

# ─── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ─── OBJECT STORAGE (MinIO / S3) ─────────────────────────
MINIO_ACCESS_KEY=qaforge
MINIO_SECRET_KEY=qaforge_secret
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ─── AUTHENTICATION ──────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# ─── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ─── FRONTEND ─────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:4000
NEXT_PUBLIC_APP_NAME=QA Forge

# ─── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=debug

# ─── EXTERNAL INTEGRATIONS (Optional) ────────────────────
# QA_JIRA_TOKEN=
# QA_LINEAR_TOKEN=
# QA_FIGMA_TOKEN=
