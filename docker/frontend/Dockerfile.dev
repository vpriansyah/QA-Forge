# ═══════════════════════════════════════════════════════════
# QA Forge — Frontend Development Dockerfile
# Hot reload with Next.js dev server
# ═══════════════════════════════════════════════════════════

FROM node:20-alpine

RUN apk add --no-cache libc6-compat

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source code (will be overridden by volume mount in dev)
COPY . .

EXPOSE 3000

# Next.js dev server
CMD ["npm", "run", "dev"]
